<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_colony_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:text="Colony Alpha" />

        <TextView
            android:id="@+id/tv_total_crew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"
            android:text="Total crew: 0" />

        <TextView
            android:id="@+id/tv_missions_completed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:text="Missions completed: 0" />

        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="3dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="12dp">

                <TextView android:text="🏠 Quarters"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:padding="8dp"/>
                <TextView android:id="@+id/tv_count_quarters"
                    android:text="0"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:textStyle="bold"
                    android:gravity="end" android:padding="8dp"/>

                <TextView android:text="🔧 Simulator"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:padding="8dp"/>
                <TextView android:id="@+id/tv_count_simulator"
                    android:text="0"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:textStyle="bold"
                    android:gravity="end" android:padding="8dp"/>

                <TextView android:text="🚀 Mission Control"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:padding="8dp"/>
                <TextView android:id="@+id/tv_count_mission"
                    android:text="0"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:textStyle="bold"
                    android:gravity="end" android:padding="8dp"/>

                <TextView android:text="🏥 Medbay"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:padding="8dp"/>
                <TextView android:id="@+id/tv_count_medbay"
                    android:text="0"
                    android:layout_width="0dp" android:layout_columnWeight="1"
                    android:textSize="14sp" android:textStyle="bold"
                    android:gravity="end" android:padding="8dp"/>

            </GridLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_recruit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recruit New Crew Member"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_go_quarters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Quarters"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_go_simulator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Simulator"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_go_mission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Mission Control"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_go_medbay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Go to Medbay"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_go_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Statistics"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    </LinearLayout>
</ScrollView>